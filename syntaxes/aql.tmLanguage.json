{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "AQL",
  "scopeName": "source.aql",
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#numbers" },
    { "include": "#constants" },
    { "include": "#clause-keywords" },
    { "include": "#keywords" },
    { "include": "#functions" },
    { "include": "#bind-parameters" },
    { "include": "#operators" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.aql",
          "match": "//.*$"
        },
        {
          "name": "comment.block.aql",
          "begin": "/\\*",
          "end": "\\*/"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.aql",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.aql",
              "match": "\\\\."
            }
          ]
        },
        {
          "name": "string.quoted.single.aql",
          "begin": "'",
          "end": "'",
          "patterns": [
            {
              "name": "constant.character.escape.aql",
              "match": "\\\\."
            }
          ]
        },
        {
          "name": "string.quoted.backtick.aql",
          "begin": "`",
          "end": "`"
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.hex.aql",
          "match": "\\b0[xX][0-9a-fA-F]+\\b"
        },
        {
          "name": "constant.numeric.float.aql",
          "match": "\\b[0-9]+\\.[0-9]+([eE][+-]?[0-9]+)?\\b"
        },
        {
          "name": "constant.numeric.integer.aql",
          "match": "\\b[0-9]+\\b"
        }
      ]
    },
    "constants": {
      "patterns": [
        {
          "name": "constant.language.boolean.aql",
          "match": "(?i)\\b(true|false)\\b"
        },
        {
          "name": "constant.language.null.aql",
          "match": "(?i)\\bnull\\b"
        }
      ]
    },
    "clause-keywords": {
      "patterns": [
        {
          "name": "keyword.control.clause.aql",
          "match": "(?i)\\b(FOR|FILTER|LET|SORT|LIMIT|COLLECT|RETURN|INSERT|UPDATE|REPLACE|REMOVE|UPSERT|WINDOW|SEARCH)\\b"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.operator.word.aql",
          "match": "(?i)\\b(AND|OR|NOT|IN|INTO|LIKE|BETWEEN|WITH|ASC|DESC|DISTINCT|AGGREGATE|OPTIONS)\\b"
        },
        {
          "name": "keyword.control.traversal.aql",
          "match": "(?i)\\b(OUTBOUND|INBOUND|ANY|ALL|NONE|GRAPH|SHORTEST_PATH|K_SHORTEST_PATHS|K_PATHS|PRUNE)\\b"
        },
        {
          "name": "keyword.other.aql",
          "match": "(?i)\\b(NEW|OLD)\\b"
        }
      ]
    },
    "functions": {
      "patterns": [
        {
          "name": "support.function.builtin.aql",
          "match": "(?i)\\b(LENGTH|COUNT|CONCAT|SUBSTRING|LOWER|UPPER|TRIM|SPLIT|MERGE|KEYS|VALUES|ATTRIBUTES|HAS|IS_NULL|IS_BOOL|IS_NUMBER|IS_STRING|IS_ARRAY|IS_OBJECT|TO_NUMBER|TO_STRING|TO_BOOL|TO_ARRAY|DATE_NOW|DATE_ISO8601|DATE_FORMAT|DATE_ADD|DATE_SUBTRACT|DATE_DIFF|DATE_YEAR|DATE_MONTH|DATE_DAY|MIN|MAX|SUM|AVERAGE|AVG|FIRST|LAST|UNIQUE|FLATTEN|SLICE|PUSH|POP|SHIFT|UNSHIFT|APPEND|REVERSE|SORTED|SORTED_UNIQUE|INTERSECTION|UNION|MINUS|GEO_POINT|GEO_DISTANCE|GEO_CONTAINS)\\b(?=\\s*\\()"
        },
        {
          "name": "entity.name.function.aql",
          "match": "\\b[a-zA-Z_][a-zA-Z0-9_]*(?=\\s*\\()"
        }
      ]
    },
    "bind-parameters": {
      "patterns": [
        {
          "name": "variable.other.bind.collection.aql",
          "match": "@@[a-zA-Z_][a-zA-Z0-9_]*"
        },
        {
          "name": "variable.other.bind.value.aql",
          "match": "@[a-zA-Z_][a-zA-Z0-9_]*"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.comparison.aql",
          "match": "==|!=|<=|>=|<|>|=~|!~"
        },
        {
          "name": "keyword.operator.arithmetic.aql",
          "match": "[+\\-*/%]"
        },
        {
          "name": "keyword.operator.logical.aql",
          "match": "&&|\\|\\|"
        },
        {
          "name": "keyword.operator.ternary.aql",
          "match": "\\?:?"
        },
        {
          "name": "keyword.operator.assignment.aql",
          "match": "="
        },
        {
          "name": "keyword.operator.range.aql",
          "match": "\\.\\."
        }
      ]
    }
  }
}
